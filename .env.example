# ---- Local data warehouse (Postgres) ----
# Matches the docker-compose.yml in this folder. Change if you run your own PG.
DWH_DATABASE_URL=postgresql://ranking:ranking@localhost:5544/ranking

# ---- Data source API keys ----
# Every source degrades gracefully: if a key is missing, that source is skipped
# (logged as "disabled") and the pipeline still runs on whatever is available.

# Google Places API (New / v1). Used for discovery + ratings + reviews.
# https://developers.google.com/maps/documentation/places/web-service
GOOGLE_MAPS_API_KEY=

# Yelp Fusion API. Used for cross-source ratings + reviews.
# https://docs.developer.yelp.com/
YELP_API_KEY=

# Firecrawl. Website scrape -> SEO/quality signals + branding/screenshot.
# https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# SEMrush. Organic keywords / traffic / backlinks / authority score.
# https://www.semrush.com/api-documentation/
SEMRUSH_API_KEY=

# Web search (SERP). Provider is adapter-based; set WEB_SEARCH_PROVIDER to one of:
#   serpapi | brave | bing
WEB_SEARCH_PROVIDER=serpapi
WEB_SEARCH_API_KEY=

# Reddit (OAuth script app). Used for organic mentions / buzz.
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=best-of-life-ranking/0.1 by yourusername

# AI search / LLM. Used for: (a) "best X in <hood>" recommendation mention-rate,
# (b) optional nuanced service-quality tagging of review text,
# (c) hot-pair nomination in the catalog stage.
# Provider adapter: openai | anthropic
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
